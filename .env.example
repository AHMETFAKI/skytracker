# SkyTracker — ortam değişkenleri şablonu
# Bu dosyayı `.env` olarak kopyalayın ve değerleri doldurun.
# `.env` git'e EKLENMEZ (bkz. .gitignore). Mock mod için anahtarlar gerekmez.

# Veri kaynağı: mock | remote  (--dart-define=DATA_SOURCE=... önceliklidir)
DATA_SOURCE=mock

# OpenSky Network — OAuth2 Client Credentials (https://opensky-network.org hesabı)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# MapTiler — harita tile/style anahtarı (https://www.maptiler.com)
MAPTILER_KEY=
